  "views": {
    "public.games_with_maps": {
      "columns": {
        "id": {
          "name": "id",
          "type": "uuid",
          "primaryKey": true,
          "notNull": true,
          "default": "gen_random_uuid()"
        },
        "name": {
          "name": "name",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        },
        "slug": {
          "name": "slug",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "select \"games\".\"id\", \"games\".\"name\", \"games\".\"slug\", \"images\".\"url\", \n          json_agg(\n            json_build_object(\n              'id', \"maps\".\"id\",\n              'name', \"maps\".\"name\",\n              'slug', \"maps\".\"slug\"\n            )\n          )\n         as \"maps\" from \"games\" inner join \"maps\" on \"maps\".\"game_id\" = \"games\".\"id\" inner join \"images\" on \"images\".\"id\" = \"games\".\"image_id\" group by \"games\".\"id\", \"games\".\"name\", \"images\".\"url\"",
      "name": "games_with_maps",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
